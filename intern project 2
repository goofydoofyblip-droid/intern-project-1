    .footer-links a {
      font-family: var(--f-mono);
      font-size: var(--t0);
      color: var(--c3);
      transition: color var(--dt);
    }
    .footer-links a:hover { color: var(--c1); }

    /* ═══════════════════════════════════════════════════
       SCROLL REVEAL — Applied via IntersectionObserver
    ═══════════════════════════════════════════════════ */
    .r {
      opacity: 0;
      translate: 0 18px;
      transition:
        opacity  var(--ds) var(--ease),
        translate var(--ds) var(--ease);
    }
    .r.visible { opacity: 1; translate: 0 0; }
    .r.d1 { transition-delay: 80ms; }
    .r.d2 { transition-delay: 160ms; }
    .r.d3 { transition-delay: 240ms; }
    .r.d4 { transition-delay: 320ms; }
  </style>
