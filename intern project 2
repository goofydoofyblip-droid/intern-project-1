    .soc:hover { color: var(--acc); border-color: var(--acc); background: var(--acc-gl); }

    /* ═══════════════════════════════════════════════════
       FOOTER — Flexbox
    ═══════════════════════════════════════════════════ */
    .footer {
      background: var(--bg);
      border-top: 1px solid var(--bdr);
      padding-block: var(--s8);
    }
    .footer-inner {
      display: flex;           /* Flexbox: logo | links */
      flex-direction: column;
      align-items: center;
      gap: var(--s4);
      text-align: center;
    }
    @media (min-width: 640px) {
      .footer-inner {
        flex-direction: row;
        justify-content: space-between;
        text-align: left;
      }
    }
    .footer-copy {
      font-family: var(--f-mono);
      font-size: var(--t0);
