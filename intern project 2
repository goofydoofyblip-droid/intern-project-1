<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Maya Santos — Creative Developer & Designer bridging engineering and craft." />
  <title>Maya Santos — Creative Developer</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9,700&family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    /* ═══════════════════════════════════════════════════
       CSS CUSTOM PROPERTIES — FULL DESIGN TOKEN SYSTEM
    ═══════════════════════════════════════════════════ */
    :root {
      /* ── Light Theme ── */
      --bg:      #F0EFF8;
      --bg2:     #E6E4F3;
      --srf:     #DAD8EE;
      --c1:      #0C0D14;
      --c2:      #525270;
      --c3:      #8E8EAC;
      --acc:     #5C4EE8;
      --acc-h:   #4437C9;
      --acc2:    #F05D2F;
      --acc-gl:  rgba(92, 78, 232, 0.10);
      --acc2-gl: rgba(240, 93, 47, 0.10);
      --bdr:     rgba(0, 0, 0, 0.07);
      --bdr2:    rgba(0, 0, 0, 0.14);
      --card:    rgba(255, 255, 255, 0.60);
      --nav:     rgba(240, 239, 248, 0.90);
      --tag-bg:  rgba(92, 78, 232, 0.09);
      --tag-c:   var(--acc);

      /* ── Typography ── */
      --f-disp: 'Fraunces', Georgia, serif;
      --f-ui:   'Space Grotesk', 'Helvetica Neue', sans-serif;
      --f-mono: 'DM Mono', 'Fira Code', monospace;

      /* ── Type Scale ── */
      --t0:  0.6875rem;
      --t1:  0.8125rem;
      --t2:  1rem;
      --t3:  1.125rem;
      --t4:  1.375rem;
      --t5:  1.75rem;
      --t6:  2.25rem;
      --t7:  clamp(2rem, 5vw, 3.25rem);
      --t8:  clamp(3.25rem, 10.5vw, 9.5rem);
      --tg:  clamp(9rem, 24vw, 22rem);

      /* ── Spacing Scale ── */
      --s1:  0.25rem;  --s2: 0.5rem;   --s3: 0.75rem;
      --s4:  1rem;     --s5: 1.25rem;  --s6: 1.5rem;
      --s8:  2rem;     --s10: 2.5rem;  --s12: 3rem;
      --s16: 4rem;     --s20: 5rem;    --s24: 6rem;

      /* ── Motion ── */
      --ease:    cubic-bezier(0.22, 1, 0.36, 1);
      --ease-io: cubic-bezier(0.76, 0, 0.24, 1);
      --dt:  160ms;
      --dm:  340ms;
      --ds:  620ms;

      /* ── Radii ── */
      --r1: 6px;  --r2: 12px;  --r3: 20px;
      --r4: 28px; --rf: 9999px;

      /* ── Shadows ── */
      --sh-s: 0 2px 10px rgba(0,0,0,0.06);
      --sh-m: 0 8px 28px rgba(0,0,0,0.08), 0 2px 8px rgba(0,0,0,0.04);
      --sh-l: 0 24px 56px rgba(0,0,0,0.11), 0 8px 20px rgba(0,0,0,0.06);

      /* ── Layout ── */
      --mw:  1380px;
      --gtr: clamp(1.25rem, 4.5vw, 3.5rem);
      --navh: 4.5rem;
    }

    /* ── Dark Theme Overrides ── */
    [data-theme="dark"] {
      --bg:      #09090F;
      --bg2:     #10101A;
      --srf:     #17172A;
      --c1:      #EEEDF8;
      --c2:      #9898B8;
      --c3:      #5C5C80;
      --acc:     #8478F8;
      --acc-h:   #9D94FA;
      --acc2:    #FF7744;
      --acc-gl:  rgba(132, 120, 248, 0.13);
      --acc2-gl: rgba(255, 119, 68, 0.12);
      --bdr:     rgba(255,255,255,0.07);
      --bdr2:    rgba(255,255,255,0.13);
      --card:    rgba(18, 18, 30, 0.88);
      --nav:     rgba(9, 9, 15, 0.92);
      --tag-bg:  rgba(132, 120, 248, 0.13);
      --tag-c:   var(--acc);
      --sh-s: 0 2px 10px rgba(0,0,0,0.30);
      --sh-m: 0 8px 28px rgba(0,0,0,0.42), 0 2px 8px rgba(0,0,0,0.25);
      --sh-l: 0 24px 56px rgba(0,0,0,0.55), 0 8px 20px rgba(0,0,0,0.35);
    }

    /* ═══════════════════════════════════════════════════
       RESET & BASE
    ═══════════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--f-ui);
      font-size: var(--t2);
      color: var(--c1);
      background: var(--bg);
      line-height: 1.65;
      overflow-x: hidden;
      transition:
        background var(--dm) var(--ease),
        color var(--dm) var(--ease);
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
      html { scroll-behavior: auto; }
    }

    h1, h2, h3, h4, h5 { font-family: var(--f-ui); line-height: 1.1; letter-spacing: -0.025em; }
    a { color: inherit; text-decoration: none; }
    img, svg { display: block; max-width: 100%; }
    ul, ol { list-style: none; }
    button { border: none; background: transparent; cursor: pointer; font: inherit; }
    em { font-style: italic; color: var(--acc); }
    ::selection { background: var(--acc); color: #fff; }
    :focus-visible { outline: 2px solid var(--acc); outline-offset: 3px; border-radius: var(--r1); }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--bdr2); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--acc); }

    /* ═══════════════════════════════════════════════════
       LAYOUT UTILITIES
    ═══════════════════════════════════════════════════ */
    .wrap {
      width: 100%;
      max-width: var(--mw);
      margin-inline: auto;
      padding-inline: var(--gtr);
    }

    /* Mobile-first section padding using clamp */
    section { padding-block: clamp(var(--s16), 10vw, var(--s24)); }

    /* ═══════════════════════════════════════════════════
       BUTTONS — Flexbox component
    ═══════════════════════════════════════════════════ */
    .btn {
      display: inline-flex;        /* Flexbox for alignment */
      align-items: center;
      gap: var(--s2);
      padding: var(--s3) var(--s6);
      font-family: var(--f-ui);
      font-size: var(--t1);
      font-weight: 500;
      letter-spacing: 0.02em;
      border-radius: var(--rf);
      border: 1.5px solid transparent;
      cursor: pointer;
      transition: all var(--dt) var(--ease);
      white-space: nowrap;
    }

    .btn-primary {
      background: var(--acc);
      color: #fff;
      border-color: var(--acc);
    }
    .btn-primary:hover {
      background: transparent;
      color: var(--acc);
      box-shadow: var(--sh-m);
      transform: translateY(-2px);
    }

    .btn-ghost {
      background: transparent;
      color: var(--c1);
      border-color: var(--bdr2);
    }
    .btn-ghost:hover {
      border-color: var(--acc);
      color: var(--acc);
      transform: translateY(-2px);
    }

    .btn-sm { padding: var(--s2) var(--s4); font-size: var(--t0); }

    /* ═══════════════════════════════════════════════════
       NAVIGATION — Flexbox layout
    ═══════════════════════════════════════════════════ */
    .nav {
      position: fixed;
      inset: 0 0 auto;
      z-index: 100;
      height: var(--navh);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      background: var(--nav);
      border-bottom: 1px solid var(--bdr);
      transition:
        background var(--dm) var(--ease),
        border-color var(--dm) var(--ease),
        box-shadow var(--dm) var(--ease);
    }

    .nav.is-scrolled { box-shadow: var(--sh-m); }

    /* Flexbox: space logo, links, actions across one row */
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
      max-width: var(--mw);
      margin-inline: auto;
      padding-inline: var(--gtr);
    }

    .nav-logo {
      font-family: var(--f-ui);
      font-size: var(--t4);
      font-weight: 700;
      letter-spacing: -0.05em;
      color: var(--c1);
      transition: color var(--dt);
    }
    .nav-logo span { color: var(--acc); }
    .nav-logo:hover { color: var(--acc); }

    /* Desktop nav links — hidden on mobile, flex on tablet+ */
    .nav-links {
      display: none;
      align-items: center;
      gap: var(--s8);
    }
    @media (min-width: 768px) { .nav-links { display: flex; } }

    .nav-links a {
      position: relative;
      font-size: var(--t1);
      font-weight: 500;
      color: var(--c2);
      transition: color var(--dt);
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1.5px;
      background: var(--acc);
      transition: width var(--dm) var(--ease);
    }
    .nav-links a:hover { color: var(--c1); }
    .nav-links a:hover::after { width: 100%; }

    /* Flexbox: group theme toggle + CTA */
    .nav-right {
      display: flex;
      align-items: center;
      gap: var(--s3);
    }

    .nav-cta { display: none; }
    @media (min-width: 768px) { .nav-cta { display: inline-flex; } }

    /* Theme toggle button */
    .theme-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem; height: 2.25rem;
      border-radius: var(--rf);
      border: 1.5px solid var(--bdr);
      color: var(--c2);
      transition: all var(--dt) var(--ease);
    }
    .theme-btn:hover { border-color: var(--acc); color: var(--acc); }
    .theme-btn svg { width: 15px; height: 15px; }

    /* Hamburger — mobile only */
    .hamburger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      width: 2.25rem; height: 2.25rem;
      border-radius: var(--r1);
      border: 1.5px solid var(--bdr);
      transition: border-color var(--dt);
    }
    @media (min-width: 768px) { .hamburger { display: none; } }
    .hamburger:hover { border-color: var(--acc); }
    .hamburger span {
      display: block;
      width: 1.1rem; height: 1.5px;
      background: var(--c1);
      transform-origin: center;
      transition: all var(--dm) var(--ease);
    }
    .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    /* Fullscreen mobile menu */
    .mobile-menu {
      position: fixed;
      inset: 0;
      z-index: 99;
      background: var(--bg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--s8);
      opacity: 0;
      pointer-events: none;
      transform: scale(0.97);
      transition: all var(--dm) var(--ease);
    }
    .mobile-menu.open { opacity: 1; pointer-events: all; transform: scale(1); }
    .mobile-menu a {
      font-family: var(--f-ui);
      font-size: var(--t6);
      font-weight: 700;
      color: var(--c1);
      transition: color var(--dt);
    }
    .mobile-menu a:hover { color: var(--acc); }

    /* ═══════════════════════════════════════════════════
       HERO — CSS Grid with named areas
    ═══════════════════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100svh;
      padding-top: var(--navh);
      display: grid;
      place-items: center;
      overflow: hidden;
    }

    /* Subtle dot-grid background texture */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, var(--bdr2) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 20%, transparent 100%);
      z-index: 0;
    }

    /* ── SIGNATURE ELEMENT: Parallax ghost text ── */
    .hero-ghost {
      position: absolute;
      font-family: var(--f-ui);
      font-weight: 700;
      font-size: var(--tg);
      line-height: 0.83;
      color: transparent;
      -webkit-text-stroke: 1px var(--bdr2);
      letter-spacing: -0.05em;
      user-select: none;
      pointer-events: none;
      top: 50%; left: 50%;
      transform: translate(-50%, -44%);
      white-space: nowrap;
      z-index: 0;
      will-change: transform;
      transition: -webkit-text-stroke-color var(--dm) var(--ease);
    }

    /* ── CSS Grid: Hero named template areas ── */
    .hero-grid {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: var(--mw);
      padding-inline: var(--gtr);
      padding-block: var(--s12);

      /* Mobile-first: single column */
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--s5);
      grid-template-areas:
        "badge"
        "name"
        "tagline"
        "bio"
        "cta"
        "stats";
    }

    /* Tablet: 2-column with named areas */
    @media (min-width: 780px) {
      .hero-grid {
        grid-template-columns: 1fr max-content;
        column-gap: var(--s16);
        row-gap: var(--s4);
        grid-template-areas:
          "badge   badge"
          "name    name"
          "tagline scroll"
          "bio     stats"
          "cta     stats";
        align-items: start;
      }
    }

    /* Desktop: 3-column asymmetric layout */
    @media (min-width: 1100px) {
      .hero-grid {
        grid-template-columns: 1fr 1fr 1fr;
        column-gap: var(--s12);
        row-gap: var(--s5);
        grid-template-areas:
          "name    name    badge"
          "name    name    badge"
          "tagline bio     stats"
          "cta     bio     scroll";
        align-items: start;
      }
    }

    /* Named area assignments */
    .hero-badge   { grid-area: badge; }
    .hero-name    { grid-area: name; }
    .hero-tagline { grid-area: tagline; }
    .hero-bio     { grid-area: bio; }
    .hero-cta     { grid-area: cta; }
    .hero-stats   { grid-area: stats; }
    .hero-scroll  { grid-area: scroll; }

    /* Status badge — Flexbox row */
    .hero-badge {
      display: flex;
      align-items: center;
      gap: var(--s2);
      font-family: var(--f-mono);
      font-size: var(--t0);
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--c3);
    }
    @media (min-width: 1100px) {
      .hero-badge {
        justify-self: end;
        align-self: end;
        padding-bottom: var(--s4);
      }
    }

    .live-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #22c55e;
      box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.22);
      animation: livepulse 2.2s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes livepulse {
      0%, 100% { box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.22); }
      50% { box-shadow: 0 0 0 7px rgba(34, 197, 94, 0.07); }
    }

    /* ── Hero name: AESTHETIC RISK — Fraunces italic serif ── */
    .hero-name {
      font-family: var(--f-disp);  /* Only place serif is used */
      font-size: var(--t8);
      font-weight: 700;
      font-style: italic;
      letter-spacing: -0.04em;
      line-height: 0.88;
      display: flex;
      flex-direction: column;
    }
    .hero-name-1 { color: var(--c1); }
    .hero-name-2 { color: var(--acc); }
    [data-theme="dark"] .hero-name-2 {
      background: linear-gradient(135deg, var(--acc), #B8B0FF);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-tagline {
      font-family: var(--f-mono);
      font-size: var(--t1);
      color: var(--c3);
      letter-spacing: 0.04em;
      padding-top: var(--s3);
      align-self: end;
    }

    .hero-bio {
      font-size: var(--t3);
      color: var(--c2);
      line-height: 1.78;
      max-width: 34ch;
    }

    /* Flexbox: row of CTA buttons */
    .hero-cta {
      display: flex;
      align-items: center;
      gap: var(--s3);
      flex-wrap: wrap;
      padding-top: var(--s2);
    }

    /* Flexbox: row/column of stats */
    .hero-stats {
      display: flex;
      gap: var(--s6);
      align-self: end;
      padding-bottom: var(--s4);
    }
    @media (min-width: 780px) {
      .hero-stats { flex-direction: column; gap: var(--s5); }
    }

    .stat-n {
      display: block;
      font-family: var(--f-ui);
      font-size: var(--t5);
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1;
      color: var(--c1);
    }
    .stat-l {
      display: block;
      font-family: var(--f-mono);
      font-size: var(--t0);
      color: var(--c3);
      letter-spacing: 0.05em;
      margin-top: 3px;
    }

    .hero-scroll {
      display: none;
      flex-direction: column;
      align-items: flex-end;
      gap: var(--s3);
      align-self: end;
      padding-bottom: var(--s4);
    }
    @media (min-width: 780px) { .hero-scroll { display: flex; } }
    .hero-scroll span {
      font-family: var(--f-mono);
      font-size: var(--t0);
      color: var(--c3);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
    }
    .scroll-bar {
      width: 1.5px; height: 56px;
      background: linear-gradient(to bottom, var(--acc), transparent);
      animation: scrollanim 2.2s ease-in-out infinite;
    }
    @keyframes scrollanim {
      0%, 100% { opacity: 0.45; transform: scaleY(0.55); }
      50% { opacity: 1; transform: scaleY(1); }
    }

    /* ═══════════════════════════════════════════════════
       SECTION LABELS & TITLES
    ═══════════════════════════════════════════════════ */
    .sec-label {
      display: inline-flex;
      align-items: center;
      gap: var(--s2);
      font-family: var(--f-mono);
      font-size: var(--t0);
      font-weight: 500;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      color: var(--acc);
      padding: 3px var(--s3);
      border: 1px solid var(--acc-gl);
      background: var(--acc-gl);
      border-radius: var(--rf);
      margin-bottom: var(--s4);
    }

    .sec-title {
      font-size: var(--t7);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--c1);
      max-width: 22ch;
    }

    .sec-head { margin-bottom: var(--s10); }

    /* ═══════════════════════════════════════════════════
       PROJECTS — CSS Grid Bento (2D layout showcase)
    ═══════════════════════════════════════════════════ */
    #work { background: var(--bg); }

    /* Mobile-first: single column */
    .bento {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--s4);
    }

    /* Small tablet: 2 columns */
    @media (min-width: 640px) {
      .bento { grid-template-columns: repeat(2, 1fr); }
    }

    /* Desktop: Complex 12-column bento grid */
    @media (min-width: 1024px) {
      .bento {
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: 380px 295px;
        gap: var(--s4);
      }
      /* Asymmetric card placement — the core CSS Grid showcase */
      .pc:nth-child(1) { grid-column: 1 / 8;  grid-row: 1; }
      .pc:nth-child(2) { grid-column: 8 / 13; grid-row: 1; }
      .pc:nth-child(3) { grid-column: 1 / 5;  grid-row: 2; }
      .pc:nth-child(4) { grid-column: 5 / 9;  grid-row: 2; }
      .pc:nth-child(5) { grid-column: 9 / 13; grid-row: 2; }
    }

    /* Project card */
    .pc {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: var(--s6);
      background: var(--card);
      border: 1px solid var(--bdr);
      border-radius: var(--r4);
      overflow: hidden;
      min-height: 280px;
      cursor: default;

      /* Reveal state: hidden until IntersectionObserver fires */
      opacity: 0;
      translate: 0 22px;
      transition:
        opacity    var(--ds) var(--ease),
        translate  var(--ds) var(--ease),
        transform  var(--dm) var(--ease),
        box-shadow var(--dm) var(--ease),
        border-color var(--dm) var(--ease);
    }
    /* Stagger delays for cascade effect */
    .pc:nth-child(2) { transition-delay: 80ms; }
    .pc:nth-child(3) { transition-delay: 160ms; }
    .pc:nth-child(4) { transition-delay: 240ms; }
    .pc:nth-child(5) { transition-delay: 320ms; }

    .pc.visible { opacity: 1; translate: 0 0; }
    .pc.visible:hover {
      transform: translateY(-5px) scale(1.007);
      box-shadow: var(--sh-l);
      border-color: var(--acc);
    }

    /* Abstract gradient visual blob per card */
    .pc-visual {
      position: absolute;
      inset: 0;
      opacity: 0.11;
      pointer-events: none;
      z-index: 0;
      transition: opacity var(--ds) var(--ease);
    }
